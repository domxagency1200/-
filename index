    function openBooking() {
      resetBookingState();
      document.getElementById('bookingModal').style.display = 'flex';
    }

    function openBookingWithService(serviceId) {
      resetBookingState();
      if (SERVICES[serviceId]) {
        selectedServices = [serviceId];
        refreshServicesUI();
        updateFinalSummary();
      }
      document.getElementById('bookingModal').style.display = 'flex';
    }

    function closeBooking() {
      document.getElementById('bookingModal').style.display = 'none';
    }

    function resetBookingState() {
      selectedServices = [];
      selectedBarber = null;
      selectedDateIso = null;
      selectedDateLabel = null;
      selectedTime = null;
      document.getElementById('modalError').textContent = '';
      document.getElementById('modalSuccess').textContent = '';
      document.getElementById('customerName').value = '';
      document.getElementById('phone').value = '';
      document.getElementById('bookingDate').value = '';
      refreshServicesUI();
      refreshBarbersUI();
      buildTimesGrid();
      updateFinalSummary();
    }

    function toggleService(serviceId) {
      var idx = selectedServices.indexOf(serviceId);
      if (idx === -1) {
        selectedServices.push(serviceId);
      } else {
        selectedServices.splice(idx, 1);
      }
      refreshServicesUI();
      updateFinalSummary();
    }

    function refreshServicesUI() {
      var cards = document.querySelectorAll('.service-option');
      cards.forEach(function (c) {
        var id = c.getAttribute('data-service-id');
        if (selectedServices.indexOf(id) !== -1) {
          c.classList.add('selected');
        } else {
          c.classList.remove('selected');
        }
      });
    }

    function selectBarber(name) {
      selectedBarber = name;
      refreshBarbersUI();
      updateFinalSummary();
    }

    function refreshBarbersUI() {
      var chips = document.querySelectorAll('.barber-chip');
      chips.forEach(function (chip) {
        var name = chip.getAttribute('data-barber');
        if (name === selectedBarber) chip.classList.add('selected');
        else chip.classList.remove('selected');
      });
    }

    function handleDateChange(value) {
      selectedDateIso = value || null;
      selectedTime = null;
      if (value) {
        var d = new Date(value + 'T00:00:00');
        var weekdayName = WEEKDAYS_AR[d.getDay()];
        selectedDateLabel = weekdayName + ' ' + d.getDate() + '/' + (d.getMonth() + 1);
      } else {
        selectedDateLabel = null;
      }
      buildTimesGrid();
      updateFinalSummary();
    }

    function generateTimeSlots() {
      var slots = [];
      var startHour = 9;
      var endHour = 17;
      var halfHours = [0, 30];
      for (var h = startHour; h <= endHour; h++) {
        for (var j = 0; j < halfHours.length; j++) {
          var m = halfHours[j];
          if (h === endHour && m === 30) {
            slots.push('17:30');
          } else if (h === endHour && m > 0) {
            continue;
          } else {
            var hh = (h < 10 ? '0' + h : '' + h);
            var mm = m === 0 ? '00' : '30';
            slots.push(hh + ':' + mm);
          }
        }
      }
      return slots;
    }

    function isSlotBooked(isoDate, time) {
      for (var i = 0; i < bookings.length; i++) {
        var b = bookings[i];
        if (b.booking_date === isoDate && b.booking_time === time && b.status !== 'cancelled') {
          return true;
        }
      }
      return false;
    }

    function buildTimesGrid() {
      var container = document.getElementById('timesGrid');
      container.innerHTML = '';
      if (!selectedDateIso) return;
      var slots = generateTimeSlots();
      for (var i = 0; i < slots.length; i++) {
        var slot = slots[i];
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'time-chip';
        btn.textContent = slot;
        if (isSlotBooked(selectedDateIso, slot)) {
          btn.classList.add('disabled');
        } else {
          (function (timeStr) {
            btn.onclick = function () {
              if (btn.classList.contains('disabled')) return;
              selectedTime = timeStr;
              var all = container.querySelectorAll('.time-chip');
              all.forEach(function (b) { b.classList.remove('selected'); });
              btn.classList.add('selected');
              updateFinalSummary();
            };
          })(slot);
        }
        if (selectedTime === slot && !isSlotBooked(selectedDateIso, slot)) {
          btn.classList.add('selected');
        }
        container.appendChild(btn);
      }
    }

    function updateFinalSummary() {
      var el = document.getElementById('finalSummary');
      if (selectedServices.length === 0 && !selectedDateIso && !selectedTime && !selectedBarber) {
        el.textContent = 'سيتم عرض ملخص الحجز هنا بعد اختيار الخدمات والتاريخ والوقت.';
        return;
      }
      var names = [];
      var totalPrice = 0;
      var totalDuration = 0;
      selectedServices.forEach(function (id) {
        var s = SERVICES[id];
        if (s) {
          names.push(s.name);
          totalPrice += s.price;
          totalDuration += s.duration;
        }
      });
      var servicesText = names.length ? names.join(' + ') : 'لم يتم اختيار خدمات بعد';
      var dateText = selectedDateLabel || 'لم يتم اختيار اليوم';
      var timeText = selectedTime || 'لم يتم اختيار الوقت';
      var barberText = selectedBarber || 'لم يتم اختيار الحلاق بعد';

      el.innerHTML =
        '<strong>الخدمات:</strong> ' + servicesText +
        ' • <strong>الحلاق:</strong> ' + barberText +
        '<br><strong>اليوم:</strong> ' + dateText +
        ' • <strong>الوقت:</strong> ' + timeText +
        '<br><strong>الإجمالي:</strong> ' + totalPrice + ' ر.س • <strong>المدة:</strong> ' + totalDuration + ' دقيقة';
    }

    function isValidPhone(phone) {
      return /^05\d{8}$/.test(phone);
    }

    // submitBk: بدون async/await
    function submitBk(event) {
      event.preventDefault();
      var errEl = document.getElementById('modalError');
      var successEl = document.getElementById('modalSuccess');
      errEl.textContent = '';
      successEl.textContent = '';

      if (selectedServices.length === 0) {
        errEl.textContent = 'الرجاء اختيار خدمة واحدة على الأقل.';
        return;
      }
      if (!selectedBarber) {
        errEl.textContent = 'الرجاء اختيار الحلاق.';
        return;
      }
      if (!selectedDateIso) {
        errEl.textContent = 'الرجاء اختيار تاريخ الحجز.';
        return;
      }
      if (!selectedTime) {
        errEl.textContent = 'الرجاء اختيار الوقت.';
        return;
      }
      if (isSlotBooked(selectedDateIso, selectedTime)) {
        errEl.textContent = 'عذراً، هذا الوقت محجوز بالفعل. الرجاء اختيار وقت آخر.';
        buildTimesGrid();
        return;
      }

      var name = document.getElementById('customerName').value.trim();
      var phone = document.getElementById('phone').value.trim();

      if (name.length < 2) {
        errEl.textContent = 'الرجاء إدخال اسم صحيح.';
        return;
      }
      if (!isValidPhone(phone)) {
        errEl.textContent = 'رقم الجوال يجب أن يتكون من 10 أرقام ويبدأ بـ 05.';
        return;
      }

      var names = [];
      var totalPrice = 0;
      var totalDuration = 0;
      selectedServices.forEach(function (id) {
        var s = SERVICES[id];
        if (s) {
          names.push(s.name);
          totalPrice += s.price;
          totalDuration += s.duration;
        }
      });

      var displayDate = selectedDateLabel || selectedDateIso;

      var booking = {
        id: 'local-' + new Date().getTime(),
        customer_name: name,
        phone: phone,
        service: 'الحلاق: ' + selectedBarber + ' • ' + names.join(' + '),
        price: totalPrice,
        duration: totalDuration,
        booking_date: selectedDateIso,
        booking_time: selectedTime,
        status: 'confirmed',
        created_at: new Date().toISOString()
      };

      addBk(booking);

      successEl.textContent = 'تم تأكيد حجزك بنجاح! يسعدنا استقبالك في فن الرجل.';
      document.getElementById('bookingForm').reset();
      resetBookingState();
      setTimeout(function () {
        closeBooking();
      }, 1400);
    }

    // addBk: يحفظ محلياً أولاً ثم Supabase بدون await
    function addBk(booking) {
      bookings.push(booking);
      saveLocal();
      refreshAllViews();

      supabaseClient
        .from('bookings')
        .insert([{
          customer_name: booking.customer_name,
          phone: booking.phone,
          service: booking.service,
          price: booking.price,
          duration: booking.duration,
          booking_date: booking.booking_date,
          booking_time: booking.booking_time,
          status: booking.status
        }])
        .then(function (result) {
          if (result && !result.error && result.data && result.data.length > 0) {
            var saved = result.data[0];
            for (var i = 0; i < bookings.length; i++) {
              if (bookings[i].id === booking.id) {
                bookings[i].id = saved.id;
                bookings[i].created_at = saved.created_at || bookings[i].created_at;
                break;
              }
            }
            saveLocal();
            refreshAllViews();
          }
        })
        .catch(function () { });
    }

    function loadLocal() {
      var raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) {
        bookings = [];
        return;
      }
      try {
        var parsed = JSON.parse(raw);
        if (parsed && parsed.length) {
          bookings = parsed;
        } else {
          bookings = [];
        }
      } catch (e) {
        bookings = [];
      }
    }

    function saveLocal() {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(bookings));
      } catch (e) {}
    }

    function syncFromSB() {
      supabaseClient
        .from('bookings')
        .select('*')
        .order('created_at', { ascending: true })
        .then(function (result) {
          if (result && !result.error && result.data) {
            bookings = result.data.map(function (b) {
              return {
                id: b.id,
                customer_name: b.customer_name,
                phone: b.phone,
                service: b.service,
                price: b.price,
                duration: b.duration,
                booking_date: b.booking_date,
                booking_time: b.booking_time,
                status: b.status || 'confirmed',
                created_at: b.created_at || new Date().toISOString()
              };
            });
            saveLocal();
            refreshAllViews();
          }
        })
        .catch(function () { });
    }

    function deleteBooking(id) {
      var idx = -1;
      for (var i = 0; i < bookings.length; i++) {
        if (String(bookings[i].id) === String(id)) {
          idx = i;
          break;
        }
      }
      if (idx === -1) return;
      bookings.splice(idx, 1);
      saveLocal();
      refreshAllViews();

      if (typeof id === 'number' || /^\d+$/.test(String(id))) {
        supabaseClient
          .from('bookings')
          .delete()
          .eq('id', id)
          .then(function () { })
          .catch(function () { });
      }
    }

    function getFilteredBookings() {
      var now = new Date();
      var todayIso = now.toISOString().slice(0, 10);

      if (currentFilter === 'all') return bookings.slice();

      var result = [];
      if (currentFilter === 'today') {
        bookings.forEach(function (b) {
          if (b.booking_date === todayIso) result.push(b);
        });
      } else if (currentFilter === 'week') {
        var day = now.getDay();
        var diffToSunday = day;
        var weekStart = new Date(now.getFullYear(), now.getMonth(), now.getDate() - diffToSunday);
        var weekEnd = new Date(weekStart.getFullYear(), weekStart.getMonth(), weekStart.getDate() + 7);
        bookings.forEach(function (b) {
          if (!b.booking_date) return;
          var d = new Date(b.booking_date);
          if (d >= weekStart && d < weekEnd) result.push(b);
        });
      } else if (currentFilter === 'month') {
        var month = now.getMonth();
        var year = now.getFullYear();
        bookings.forEach(function (b) {
          if (!b.booking_date) return;
          var d = new Date(b.booking_date);
          if (d.getMonth() === month && d.getFullYear() === year) result.push(b);
        });
      }
      return result;
    }

    function refreshStats() {
      var list = getFilteredBookings();
      var total = list.length;
      var revenue = 0;
      for (var i = 0; i < list.length; i++) {
        var p = parseFloat(list[i].price || 0);
        if (!isNaN(p)) revenue += p;
      }
      var avg = total > 0 ? Math.round(revenue / total) : 0;

      var now = new Date();
      var todayIso = now.toISOString().slice(0, 10);
      var allToday = 0;
      bookings.forEach(function (b) {
        if (b.booking_date === todayIso) allToday++;
      });

      document.getElementById('statTotal').textContent = total;
      document.getElementById('statRevenue').textContent = revenue;
      document.getElementById('statAverage').textContent = avg;
      document.getElementById('statToday').textContent = allToday;

      var weekBookings = 0;
      var day = now.getDay();
      var diffToSunday = day;
      var weekStart = new Date(now.getFullYear(), now.getMonth(), now.getDate() - diffToSunday);
      var weekEnd = new Date(weekStart.getFullYear(), weekStart.getMonth(), weekStart.getDate() + 7);
      bookings.forEach(function (b) {
        if (!b.booking_date) return;
        var d = new Date(b.booking_date);
        if (d >= weekStart && d < weekEnd) weekBookings++;
      });
      document.getElementById('heroWeekBookings').textContent = weekBookings;
      document.getElementById('heroAvgRevenue').textContent = avg;

      var loyal = Math.round(bookings.length * 0.6);
      document.getElementById('aboutLoyalClients').textContent = loyal;

      var nextSlot = findNextAvailableSlot();
      document.getElementById('heroNextSlot').textContent = nextSlot;
    }

    function findNextAvailableSlot() {
      var now = new Date();
      for (var i = 0; i < 7; i++) {
        var d = new Date(now.getFullYear(), now.getMonth(), now.getDate() + i);
        var iso = d.toISOString().slice(0, 10);
        var slots = generateTimeSlots();
        for (var j = 0; j < slots.length; j++) {
          if (!isSlotBooked(iso, slots[j])) {
            var label = (i === 0 ? 'اليوم' : (i === 1 ? 'غداً' : WEEKDAYS_AR[d.getDay()]));
            return label + ' ' + slots[j];
          }
        }
      }
      return 'غير متاح حالياً';
    }

    function refreshAdminTable() {
      var tbody = document.getElementById('adminTableBody');
      tbody.innerHTML = '';
      var list = getFilteredBookings();
      list.sort(function (a, b) {
        var aKey = (a.booking_date || '') + ' ' + (a.booking_time || '');
        var bKey = (b.booking_date || '') + ' ' + (b.booking_time || '');
        return aKey < bKey ? -1 : aKey > bKey ? 1 : 0;
      });
      for (var i = 0; i < list.length; i++) {
        var b = list[i];
        var tr = document.createElement('tr');
        tr.innerHTML =
          '<td>' + (b.customer_name || '') + '</td>' +
          '<td>' + (b.service || '') + '</td>' +
          '<td>' + (b.booking_date || '') + '</td>' +
          '<td>' + (b.booking_time || '') + '</td>' +
          '<td>' + (b.price || 0) + '</td>' +
          '<td><button class="btn-delete" onclick="deleteBooking(' + JSON.stringify(b.id) + ')">حذف</button></td>';
        tbody.appendChild(tr);
      }
    }

    function buildCalendar() {
      var container = document.getElementById('calendarWeek');
      container.innerHTML = '';
      var now = new Date();
      var day = now.getDay();
      var diffToSunday = day;
      var weekStart = new Date(now.getFullYear(), now.getMonth(), now.getDate() - diffToSunday);
      var weekEnd = new Date(weekStart.getFullYear(), weekStart.getMonth(), weekStart.getDate() + 7);
      var label = weekStart.getDate() + '/' + (weekStart.getMonth() + 1) + ' - ' +
        weekEnd.getDate() + '/' + (weekEnd.getMonth() + 1);
      document.getElementById('calendarWeekLabel').textContent = label;

      var activeIso = weekStart.toISOString().slice(0, 10);
      for (var i = 0; i < 7; i++) {
        var d = new Date(weekStart.getFullYear(), weekStart.getMonth(), weekStart.getDate() + i);
        var iso = d.toISOString().slice(0, 10);
        var count = 0;
        bookings.forEach(function (b) {
          if (b.booking_date === iso) count++;
        });
        var dayEl = document.createElement('div');
        dayEl.className = 'calendar-day' + (iso === activeIso ? ' active' : '');
        dayEl.setAttribute('data-iso', iso);
        dayEl.innerHTML =
          '<div class="calendar-day-name">' + WEEKDAYS_AR[d.getDay()] + '</div>' +
          '<div class="calendar-day-date">' + d.getDate() + '</div>' +
          '<div class="calendar-day-count">' + count + ' حجز</div>';
        (function (isoDate) {
          dayEl.onclick = function () {
            var all = container.querySelectorAll('.calendar-day');
            all.forEach(function (x) { x.classList.remove('active'); });
            dayEl.classList.add('active');
            showCalendarDetail(isoDate);
          };
        })(iso);
        container.appendChild(dayEl);
      }
      showCalendarDetail(activeIso);
    }

    function showCalendarDetail(isoDate) {
      var box = document.getElementById('calendarDetail');
      box.innerHTML = '';
      var list = [];
      bookings.forEach(function (b) {
        if (b.booking_date === isoDate) list.push(b);
      });
      if (list.length === 0) {
        box.textContent = 'لا توجد حجوزات مسجلة لهذا اليوم.';
        return;
      }
      list.sort(function (a, b) {
        return (a.booking_time || '') < (b.booking_time || '') ? -1 : 1;
      });
      for (var i = 0; i < list.length; i++) {
        var b = list[i];
        var div = document.createElement('div');
        div.className = 'calendar-detail-item';
        div.textContent = (b.booking_time || '') + ' — ' + (b.customer_name || '') + ' (' + (b.service || '') + ')';
        box.appendChild(div);
      }
    }

    function refreshAllViews() {
      refreshStats();
      refreshAdminTable();
      buildCalendar();
      buildTimesGrid();
    }

    function setAdminFilter(filter) {
      currentFilter = filter;
      var chips = document.querySelectorAll('.filter-chip');
      chips.forEach(function (c) {
        var val = c.getAttribute('data-filter');
