### هذا هو الملف بعد تعديل كل المطلوب

> انسخ الكود كاملاً إلى ملف `index.html` (أو الملف الحالي) بدل الكود السابق.

```html
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <title>فن الرجل - حلاقة رجالية فاخرة</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- خطوط -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet">
  <!-- Supabase -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    :root {
      --bg-main: #080808;
      --bg-alt: #0f0f0f;
      --bg-alt-2: #161616;
      --gold: #C9A84C;
      --gold-soft: rgba(201, 168, 76, 0.15);
      --text-main: #f5f5f5;
      --text-muted: #aaaaaa;
      --danger: #ff4d4f;
      --success: #2ecc71;
      --radius-lg: 18px;
      --radius-md: 12px;
      --transition-fast: 0.25s ease;
      --shadow-soft: 0 18px 45px rgba(0,0,0,0.65);
    }
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      background: radial-gradient(circle at top, #161616 0, #080808 40%, #000 100%);
      color: var(--text-main);
      font-family: 'Tajawal', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.7;
      scroll-behavior: smooth;
    }
    img {
      max-width: 100%;
      display: block;
    }
    a {
      color: inherit;
      text-decoration: none;
    }
    button {
      font-family: inherit;
    }

    /* توب بار + تيكر */
    .top-bar {
      background: linear-gradient(90deg, #0d0d0d, #161616);
      border-bottom: 1px solid rgba(255,255,255,0.05);
      color: var(--gold);
      font-size: 0.85rem;
      position: relative;
      z-index: 30;
      overflow: hidden;
    }
    .top-bar-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 6px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .top-bar-label {
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-size: 0.7rem;
      color: #f1e8c4;
      white-space: nowrap;
    }
    .ticker-wrapper {
      position: relative;
      flex: 1;
      overflow: hidden;
    }
    .ticker-track {
      display: flex;
      gap: 40px;
      white-space: nowrap;
      animation: tickerMove 26s linear infinite;
    }
    .ticker-item {
      color: var(--text-main);
      font-size: 0.85rem;
      opacity: 0.9;
    }
    .ticker-dot {
      color: rgba(201,168,76,0.7);
      margin: 0 4px;
    }
    @keyframes tickerMove {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* نافبار */
    .navbar {
      position: fixed;
      top: 0;
      inset-inline: 0;
      z-index: 40;
      backdrop-filter: blur(18px);
      background: linear-gradient(to bottom, rgba(8,8,8,0.96), rgba(8,8,8,0.8), transparent);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .navbar-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
    }
    .brand-mark {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(201,168,76,0.8);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      color: var(--gold);
      background: radial-gradient(circle at top, rgba(201,168,76,0.2), rgba(0,0,0,0.9));
      box-shadow: 0 0 24px rgba(201,168,76,0.4);
    }
    .brand-mark svg {
      width: 18px;
      height: 18px;
      fill: var(--gold);
    }
    .brand-text {
      display: flex;
      flex-direction: column;
    }
    .brand-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .brand-sub {
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 18px;
      font-size: 0.9rem;
    }
    .nav-link {
      position: relative;
      padding-bottom: 4px;
      cursor: pointer;
      color: var(--text-muted);
      transition: color var(--transition-fast);
    }
    .nav-link::after {
      content: "";
      position: absolute;
      inset-inline: 0;
      bottom: 0;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(201,168,76,0), rgba(201,168,76,0.9), rgba(201,168,76,0));
      opacity: 0;
      transform: scaleX(0.5);
      transition: opacity var(--transition-fast), transform var(--transition-fast);
    }
    .nav-link:hover {
      color: #ffffff;
    }
    .nav-link:hover::after {
      opacity: 1;
      transform: scaleX(1);
    }
    .btn-primary {
      padding: 8px 20px;
      border-radius: 999px;
      border: none;
      background: linear-gradient(135deg, #C9A84C, #f6e6a8);
      color: #241e08;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 10px 30px rgba(201,168,76,0.5);
      transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
      white-space: nowrap;
    }
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 16px 40px rgba(201,168,76,0.65);
      filter: brightness(1.05);
    }
    .btn-outline {
      padding: 8px 18px;
      border-radius: 999px;
      border: 1px solid rgba(201,168,76,0.6);
      background: transparent;
      color: var(--gold);
      cursor: pointer;
      font-size: 0.9rem;
      transition: background var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .btn-outline:hover {
      background: rgba(201,168,76,0.12);
      box-shadow: 0 10px 28px rgba(0,0,0,0.7);
    }
    .nav-toggle {
      display: none;
      width: 32px;
      height: 32px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(0,0,0,0.3);
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }
    .nav-toggle span {
      display: block;
      width: 16px;
      height: 2px;
      border-radius: 999px;
      background: #fff;
      position: relative;
    }
    .nav-toggle span::before,
    .nav-toggle span::after {
      content: "";
      position: absolute;
      inset-inline-start: 0;
      width: 16px;
      height: 2px;
      border-radius: 999px;
      background: #fff;
    }
    .nav-toggle span::before { top: -5px; }
    .nav-toggle span::after { top: 5px; }

    /* هيرو بخلفية كاملة */
    .hero {
      min-height: 100vh;
      padding-top: 120px;
      display: flex;
      align-items: center;
      position: relative;
      background-image: url("https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1600&q=80");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      isolation: isolate;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top, rgba(0,0,0,0.3), rgba(0,0,0,0.92));
      z-index: -1;
    }
    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px 70px;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 40px;
      align-items: center;
    }
    .hero-eyebrow {
      font-size: 0.85rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
    }
    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 4vw, 3.2rem);
      line-height: 1.1;
      margin-bottom: 14px;
    }
    .hero-title span {
      color: var(--gold);
    }
    .hero-subtitle {
      font-size: 1rem;
      color: var(--text-muted);
      max-width: 480px;
      margin-bottom: 22px;
    }
    .hero-highlights {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-bottom: 26px;
    }
    .chip {
      padding: 6px 12px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(0,0,0,0.6);
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      align-items: center;
    }
    .hero-note {
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .hero-note span {
      color: var(--gold);
    }
    .hero-visual {
      position: relative;
      height: 380px;
      border-radius: 30px;
      overflow: hidden;
      background: radial-gradient(circle at top, #2b2211, #050505);
      box-shadow: 0 28px 70px rgba(0,0,0,0.9);
      isolation: isolate;
      cursor: pointer;
    }
    .hero-visual-img {
      position: absolute;
      inset: 0;
      background-image: url("https://images.unsplash.com/photo-1585747860715-2ba37e788b70?auto=format&fit=crop&w=1200&q=80");
      background-size: cover;
      background-position: center;
      filter: saturate(0.9) contrast(1.05);
      transform: scale(1.04);
      transition: transform 0.6s ease, filter 0.6s ease;
    }
    .hero-visual-overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top, rgba(0,0,0,0), rgba(0,0,0,0.7));
      mix-blend-mode: multiply;
    }
    .hero-visual:hover .hero-visual-img {
      transform: scale(1.06);
      filter: saturate(1.05) contrast(1.1);
    }
    .ribbon {
      position: absolute;
      inset-inline-start: 20px;
      top: 18px;
      padding: 6px 14px;
      border-radius: 999px;
      background: rgba(0,0,0,0.7);
      border: 1px solid rgba(201,168,76,0.7);
      font-size: 0.8rem;
      color: var(--gold);
      display: flex;
      align-items: center;
      gap: 6px;
      backdrop-filter: blur(16px);
    }
    .ribbon-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--success);
      box-shadow: 0 0 10px var(--success);
    }
    .hero-stats {
      position: absolute;
      inset-inline-end: 20px;
      bottom: 18px;
      padding: 12px 14px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(0,0,0,0.95), rgba(16,16,16,0.95));
      border: 1px solid rgba(255,255,255,0.08);
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      backdrop-filter: blur(16px);
    }
    .hero-stat {
      font-size: 0.8rem;
    }
    .hero-stat-label {
      color: var(--text-muted);
      margin-bottom: 4px;
    }
    .hero-stat-value {
      font-weight: 600;
      color: #ffffff;
    }

    /* أقسام عامة */
    section {
      scroll-margin-top: 80px;
    }
    .section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 20px 10px;
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 24px;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
    }
    .section-kicker {
      font-size: 0.85rem;
      color: var(--gold);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }
    .section-sub {
      font-size: 0.9rem;
      color: var(--text-muted);
    }

    /* الخدمات */
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
    }
    .card {
      position: relative;
      padding: 18px 18px 16px;
      border-radius: var(--radius-lg);
      background: radial-gradient(circle at top, rgba(255,255,255,0.02), rgba(0,0,0,0.85));
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: var(--shadow-soft);
      overflow: hidden;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }
    .card:hover {
      transform: translateY(-4px);
      border-color: rgba(201,168,76,0.7);
      box-shadow: 0 22px 55px rgba(0,0,0,0.85);
      background: radial-gradient(circle at top, rgba(201,168,76,0.06), rgba(0,0,0,0.9));
    }
    .card-highlight {
      position: absolute;
      inset-inline-start: 0;
      inset-block-start: 0;
      width: 60%;
      height: 60%;
      background: radial-gradient(circle at top, rgba(201,168,76,0.12), transparent 60%);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.18s ease;
    }
    .card:hover .card-highlight {
      opacity: 1;
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 10px;
    }
    .card-title {
      font-weight: 600;
      font-size: 1.05rem;
    }
    .card-pill {
      font-size: 0.8rem;
      padding: 4px 10px;
      border-radius: 999px;
      border: 1px solid rgba(201,168,76,0.6);
      background: rgba(0,0,0,0.6);
      color: var(--gold);
    }
    .card-body {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 12px;
    }
    .card-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .price {
      color: var(--gold);
      font-weight: 600;
      font-size: 0.95rem;
    }

    /* الباقات */
    .plan-card {
      padding-top: 26px;
      padding-bottom: 18px;
    }
    .badge-popular {
      position: absolute;
      top: 12px;
      inset-inline-end: 18px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 0.75rem;
      background: linear-gradient(135deg, #C9A84C, #f5ebc4);
      color: #1b1707;
      font-weight: 600;
      box-shadow: 0 12px 30px rgba(201,168,76,0.6);
    }
    .plan-price {
      font-size: 1.4rem;
      font-weight: 600;
      color: #fff;
      margin-bottom: 6px;
    }
    .plan-price span {
      font-size: 0.8rem;
      color: var(--text-muted);
      font-weight: 400;
    }
    .plan-features {
      margin: 10px 0 6px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }

    /* عن الحلاق + خريطة */
    .about-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 30px;
      align-items: center;
    }
    .about-card {
      padding: 22px 20px 18px;
      border-radius: var(--radius-lg);
      background: radial-gradient(circle at top, rgba(255,255,255,0.02), rgba(0,0,0,0.9));
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: var(--shadow-soft);
    }
    .about-name {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 6px;
    }
    .about-role {
      font-size: 0.9rem;
      color: var(--gold);
      margin-bottom: 10px;
    }
    .about-text {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 16px;
    }
    .stats-row {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
    }
    .stat-card {
      flex: 1;
      min-width: 120px;
      padding: 10px 12px;
      border-radius: 14px;
      background: rgba(0,0,0,0.7);
      border: 1px solid rgba(255,255,255,0.08);
    }
    .stat-label {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 4px;
    }
    .stat-value {
      font-size: 1.1rem;
      font-weight: 600;
      color: #fff;
    }
    .about-map {
      border-radius: 26px;
      overflow: hidden;
      box-shadow: 0 22px 60px rgba(0,0,0,0.9);
      border: 1px solid rgba(255,255,255,0.08);
      min-height: 260px;
    }
    .about-map iframe {
      width: 100%;
      height: 100%;
      border: 0;
    }

    /* التقييمات */
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 20px;
    }
    .rating-stars {
      color: #f2da7b;
      font-size: 0.9rem;
      margin-bottom: 6px;
    }
    .testimonial-name {
      font-size: 0.9rem;
      font-weight: 500;
    }
    .testimonial-meta {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-bottom: 10px;
    }

    /* فوتر */
    .footer {
      margin-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 20px;
      background: linear-gradient(to top, #050505, transparent);
    }
    .footer-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      font-size: 0.85rem;
      color: var(--text-muted);
    }
    .footer-link {
      color: var(--gold);
      cursor: pointer;
      border-bottom: 1px dotted rgba(201,168,76,0.5);
    }

    /* مودال الحجز (كل شيء في شاشة واحدة) */
    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 100;
      backdrop-filter: blur(8px);
    }
    .modal {
      width: min(760px, 100% - 24px);
      max-height: calc(100vh - 40px);
      background: radial-gradient(circle at top, #161616, #050505);
      border-radius: 22px;
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 24px 70px rgba(0,0,0,0.85);
      padding: 18px 18px 16px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      padding-bottom: 8px;
    }
    .modal-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
    }
    .modal-subtitle {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin-top: 2px;
    }
    .modal-close {
      border-radius: 999px;
      width: 30px;
      height: 30px;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(0,0,0,0.5);
      cursor: pointer;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .modal-body {
      overflow-y: auto;
      padding: 4px 2px 4px;
      flex: 1;
    }
    .form-row-two {
      display: grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap: 10px;
      margin-bottom: 10px;
    }
    .field {
      display: flex;
      flex-direction: column;
      gap: 4px;
      font-size: 0.8rem;
    }
    .field label {
      color: var(--text-muted);
    }
    .field input {
      padding: 8px 10px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.14);
      background: rgba(0,0,0,0.7);
      color: #fff;
      font-family: inherit;
      font-size: 0.85rem;
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .field input:focus {
      border-color: rgba(201,168,76,0.9);
      box-shadow: 0 0 0 1px rgba(201,168,76,0.3);
    }
    .section-block-title {
      font-size: 0.9rem;
      font-weight: 600;
      margin: 8px 0 4px;
    }
    .section-block-sub {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-bottom: 6px;
    }
    .services-select-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0,1fr));
      gap: 10px;
      margin-bottom: 8px;
    }
    .service-option {
      position: relative;
      padding: 10px 10px 8px;
      border-radius: 14px;
      background: rgba(0,0,0,0.75);
      border: 1px solid rgba(255,255,255,0.12);
      cursor: pointer;
      font-size: 0.85rem;
      display: flex;
      flex-direction: column;
      gap: 4px;
      transition: border-color var(--transition-fast), background var(--transition-fast), box-shadow var(--transition-fast), transform 0.15s ease;
    }
    .service-option:hover {
      border-color: rgba(201,168,76,0.8);
      box-shadow: 0 10px 28px rgba(0,0,0,0.8);
      transform: translateY(-2px);
    }
    .service-option.selected {
      border-color: rgba(201,168,76,1);
