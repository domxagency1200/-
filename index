    }
    .admin-table th,
    .admin-table td {
      padding: 6px 4px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      text-align: center;
    }
    .admin-table th {
      color: var(--text-muted);
      font-weight: 500;
      position: sticky;
      top: 0;
      background: rgba(0,0,0,0.9);
      z-index: 1;
    }
    .btn-delete {
      padding: 4px 10px;
